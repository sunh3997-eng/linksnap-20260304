# ── LinkSnap 环境变量配置 ────────────────────────────────────────────────────
# 复制此文件为 .env，然后填写真实值

# OpenAI API Key（必填，用于生成摘要）
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI 模型（默认 gpt-4o-mini，便宜且够用）
OPENAI_MODEL=gpt-4o-mini

# Flask 运行环境 development | production
FLASK_ENV=development

# 服务监听端口
PORT=5000

# SQLite 数据库文件路径
DATABASE_PATH=linksnap.db

# 免费额度（每用户每月可保存条数）
FREE_TIER_LIMIT=100

# 允许跨域的来源（多个用英文逗号分隔，* 表示全部允许）
CORS_ORIGINS=*
